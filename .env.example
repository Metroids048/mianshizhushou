# Remote LLM fallback chain: OpenRouter -> GitHub Models -> DeepSeek -> local practice
OPENROUTER_API_KEY=
OPENROUTER_MODEL_POOL=openrouter/free
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL_POOL=openai/gpt-4.1-mini
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# System-audio ASR: xfyun, local-whisper, or debug
ASR_PROVIDER=local-whisper
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DOWNLOAD_ROOT=.data/whisper-models
# LOCAL_WHISPER_PYTHON=C:\absolute\path\to\python.exe

# XFYUN_RTASR_APP_ID=
# XFYUN_RTASR_API_KEY=
